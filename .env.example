# IcePhone environment template
# Copy this file to `.env` for local development.
# Drizzle commands read `.env` by default. To target a different file, set
# `ICEPHONE_ENV_FILE=/absolute/or/relative/path/to/file` before running them.

# Core application
APP_NAME=IcePhone
APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_NON_PAYMENT_DISABLED=false

# Authentication (required)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Database (required)
DEV_DB_URL=postgres://postgres:postgres@127.0.0.1:5432/icephone_dev
PROD_DB_URL=postgres://postgres:postgres@127.0.0.1:5432/icephone_prod

# Email
RESEND_API_KEY=
EMAIL_FROM_NAME=IcePhone
EMAIL_FROM_ADDRESS=

# AI providers
OPENAI_API_KEY=
OPENAI_REALTIME_VOICE=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
VOYAGE_API_KEY=

# Cloudflare R2 storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Cal.com scheduling
CALCOM_API_BASE_URL=
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
CALCOM_EVENT_TYPE_SLUG=
CALCOM_TEAM_SLUG=
CALCOM_USERNAME=
CALCOM_ORGANIZATION_SLUG=
CALCOM_DEFAULT_TIMEZONE=UTC

# Queue and campaign processors
# Required only when enabling the protected processing endpoints.
CALL_QUEUE_PROCESSOR_SECRET=
CAMPAIGN_PROCESSOR_SECRET=
CALL_EXECUTION_ENABLED=false
CALL_EXECUTION_PROVIDER=mock

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_OUTBOUND_TWIML_URL=
TWILIO_STATUS_CALLBACK_URL=
TWILIO_RECORD_CALLS=false

# Telnyx
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_FROM_NUMBER=
TELNYX_WEBHOOK_URL=
TELNYX_PUBLIC_KEY=
TELNYX_API_PUBLIC_KEY=

# Vonage
VONAGE_APPLICATION_ID=
VONAGE_PRIVATE_KEY=
VONAGE_FROM_NUMBER=
VONAGE_ANSWER_URL=
VONAGE_EVENT_URL=
VONAGE_WEBHOOK_SIGNATURE_SECRET=
VONAGE_SIGNATURE_SECRET=
VONAGE_API_SIGNATURE_SECRET=
VONAGE_APPLICATION_SECRET=

# Development-only escape hatch. Keep false in any shared or production environment.
TELEPHONY_WEBHOOK_ALLOW_UNSIGNED=false

# Platform-provided deployment URLs
VERCEL_URL=
VERCEL_BRANCH_URL=
