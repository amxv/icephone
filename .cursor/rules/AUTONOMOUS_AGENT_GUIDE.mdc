## 🏆 Key Patterns for Success

### The React Compiler Advantage

Let the compiler optimize your code automatically:

```jsx
// Just write clean code - no manual optimization needed
function LeadsList({ leads, searchTerm }) {
  const filteredLeads = leads.filter(lead =>
    lead.name.toLowerCase().includes(searchTerm.toLowerCase())
  );

  return (
    <div>
      {filteredLeads.map(lead => (
        <LeadCard key={lead.id} lead={lead} />
      ))}
    </div>
  );
}
```

Only manually optimize expensive operations:

```jsx
// Keep useMemo for truly expensive calculations
const processedAnalytics = useMemo(() => {
  return rawCallData
    .filter(call => call.duration > 30)
    .map(call => calculateSentimentScore(call.transcript))
    .sort((a, b) => b.score - a.score);
}, [rawCallData]);
```

### Security Pattern (Non-Negotiable)

Every server action MUST authenticate:

```typescript
'use server';
import { currentUser } from '@clerk/nextjs/server';

export async function createLead(input: LeadInput) {
  const user = await currentUser();
  if (!user) throw new Error('Unauthorized');

  return await db.insert(leads).values({
    ...input,
    userId: user.id  // CRITICAL: Always scope to user
  });
}
```

### Smart Data Loading

Use server components for initial data:

```typescript
// ✅ Server component loads data
export default async function LeadsPage() {
  const leads = await getLeads();
  return <LeadsClient initialLeads={leads} />;
}

// ✅ Client component handles interactions
'use client';
export function LeadsClient({ initialLeads }) {
  const [leads, setLeads] = useState(initialLeads);
  // Interactive features here
}
```

### Background Tasks

Use Next.js `after` for non-blocking operations:

```typescript
import { unstable_after as after } from 'next/server';

export async function processCall(callId: string) {
  const call = await updateCallStatus(callId, 'completed');

  // These run after response is sent
  after(async () => {
    await generateTranscript(callId);
    await updateAnalytics(call.leadId);
    await sendFollowupEmail(call.leadId);
  });

  return call;
}
```

