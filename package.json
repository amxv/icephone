{
	"name": "clerk-nextjs-app-quickstart",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "( : > logs/server.log && FORCE_COLOR=1 next dev --turbopack 2>&1 ) | tee >(perl -pe 's/\\x1B\\[[0-9;]*[a-zA-Z]//g; $|=1' | while IFS= read -r line; do printf \"[%s] %s\\n\" \"$(date +'%Y-%m-%d %H:%M:%S')\" \"$line\" >> logs/server.log; done)",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"check": "bun typecheck && bunx biome check --write .",
		"clean-next": "rm -rf .next",
		"reinstall-deps": "rm -rf node_modules && bun install",
		"db:seed": "bun scripts/seed-db.ts",
		"db:dev:generate": "bunx drizzle-kit generate --config=drizzle.config.dev.ts",
		"db:dev:migrate": "bunx drizzle-kit migrate --config=drizzle.config.dev.ts",
		"db:dev:push": "bunx drizzle-kit push --config=drizzle.config.dev.ts",
		"db:prod:generate": "bunx drizzle-kit generate --config=drizzle.config.prod.ts",
		"db:prod:migrate": "bunx drizzle-kit migrate --config=drizzle.config.prod.ts",
		"db:prod:push": "bunx drizzle-kit push --config=drizzle.config.prod.ts",
		"typecheck": "tsc --noEmit",
		"filetree": "tree -I \"node_modules|.*|public|screenshots\"",
		"get-screenshot-paths": "find screenshots -type f -name \"*.png\" -exec stat -f \"%m %N\" {} \\; | sort -nr | head -n 2 | awk '{print $2}' | xargs realpath | awk 'NR==2 {print \"before path: \", $0} NR==1 {print \"after path: \", $0}'",
		"prepare": "husky",
		"fix": "pkill node || true && rm -rf .next && rm -rf node_modules && bun install && bun dev",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"deploy": "bun check && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
		"browser-mcp": "bunx @agentdeskai/browser-tools-server@latest"
	},
	"dependencies": {
		"@clerk/nextjs": "^6.16.0",
		"@neondatabase/serverless": "^1.0.0",
		"@opennextjs/cloudflare": "^1.0.0-beta.3",
		"@radix-ui/react-collapsible": "^1.1.7",
		"@radix-ui/react-dialog": "^1.1.10",
		"@radix-ui/react-dropdown-menu": "^2.1.10",
		"@radix-ui/react-popover": "^1.1.10",
		"@radix-ui/react-select": "^2.2.2",
		"@radix-ui/react-separator": "^1.1.4",
		"@radix-ui/react-slot": "^1.2.0",
		"@radix-ui/react-tooltip": "^1.2.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^16.5.0",
		"drizzle-orm": "^0.42.0",
		"framer-motion": "^12.7.4",
		"lucide-react": "^0.501.0",
		"next": "15.2.3",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tailwind-merge": "^3.2.0",
		"tw-animate-css": "^1.2.5",
		"vaul": "^1.1.2",
		"wrangler": "^4.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@opennextjs/aws": "^3.5.8",
		"@tailwindcss/postcss": "^4.1.4",
		"@types/node": "^22.14.1",
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"drizzle-kit": "^0.31.0",
		"husky": "^9.1.7",
		"postcss": "^8.5.3",
		"tailwindcss": "^4.1.4",
		"typescript": "^5.8.3"
	}
}
